{
  "name": "life-ops-workspace",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "life-ops-workspace",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@lifeops/core": {
      "resolved": "packages/life-ops-core",
      "link": true
    },
    "node_modules/lifeops": {
      "resolved": "packages/lifeops-cli",
      "link": true
    },
    "packages/life-ops-core": {
      "name": "@lifeops/core",
      "version": "0.1.0",
      "license": "MIT",
      "engines": {
        "node": ">=20"
      }
    },
    "packages/lifeops-cli": {
      "name": "lifeops",
      "version": "0.3.5",
      "license": "MIT",
      "bin": {
        "cmail": "bin/cmail.js",
        "lifeops": "bin/lifeops.js"
      },
      "engines": {
        "node": ">=20"
      }
    }
  }
}
