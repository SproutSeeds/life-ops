#!/bin/zsh
set -euo pipefail

ROOT_DIR="${0:A:h:h}"
SESSION_NAME="${LIFE_OPS_GMAIL_EXHAUST_SESSION:-life-ops-gmail-exhaust}"
LOG_PATH="${ROOT_DIR}/data/logs/gmail-full-exhaust.log"

mkdir -p "${ROOT_DIR}/data/logs"

usage() {
  cat <<EOF
Usage: zsh ./bin/gmail-exhaust <command>

Commands:
  start   Start or resume the persistent Gmail backlog runner in tmux
  restart Start the runner from a fresh full-backlog reset
  status  Show the current Gmail heartbeat
  attach  Attach to the tmux session
  tail    Tail the backlog log
  stop    Stop the tmux session
EOF
}

command_name="${1:-start}"

case "${command_name}" in
  start)
    extra_args=()
    ;;
  restart)
    extra_args=(--reset-backfill-cursor)
    ;;
  status)
    cd "${ROOT_DIR}"
    exec zsh ./bin/life-ops gmail-heartbeat
    ;;
  attach)
    exec tmux attach -t "${SESSION_NAME}"
    ;;
  tail)
    touch "${LOG_PATH}"
    exec tail -f "${LOG_PATH}"
    ;;
  stop)
    tmux kill-session -t "${SESSION_NAME}"
    echo "Stopped Gmail exhaust session '${SESSION_NAME}'."
    ;;
  *)
    usage
    exit 1
    ;;
esac

if [[ "${command_name}" == "start" || "${command_name}" == "restart" ]]; then
    if tmux has-session -t "${SESSION_NAME}" 2>/dev/null; then
      echo "Gmail exhaust session '${SESSION_NAME}' is already running."
      exit 0
    fi
    sync_command="cd ${ROOT_DIR:q} && while true; do zsh ./bin/life-ops sync-gmail-corpus --backfill-query=-in:chats --backfill-max-results 250 --backfill-max-runs 0 ${extra_args[*]} >> ${LOG_PATH:q} 2>&1; status=\$?; if [[ \$status -eq 0 ]]; then break; fi; printf '[%s] gmail exhaust runner exited with status %s, retrying in 10s\n' \"\$(date '+%Y-%m-%d %H:%M:%S %Z')\" \"\$status\" >> ${LOG_PATH:q}; sleep 10; done"
    tmux new-session -d -s "${SESSION_NAME}" "${sync_command}"
    echo "Started Gmail exhaust session '${SESSION_NAME}'."
fi
