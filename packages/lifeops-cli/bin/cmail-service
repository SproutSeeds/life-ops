#!/bin/zsh
set -euo pipefail

PACKAGE_DIR="${0:A:h:h}"
SCRIPT_PATH="${0:A}"
LABEL="${LIFE_OPS_CMAIL_LABEL:-com.frg.lifeops.cmail}"
WATCHDOG_LABEL="${LABEL}.watchdog"
STATE_ROOT="${LIFE_OPS_HOME:-${HOME}/.lifeops}"
STATE_BIN_DIR="${STATE_ROOT}/bin"
AGENT_DIR="${HOME}/Library/LaunchAgents"
PLIST_PATH="${AGENT_DIR}/${LABEL}.plist"
WATCHDOG_PLIST_PATH="${AGENT_DIR}/${WATCHDOG_LABEL}.plist"
SERVICE_LOG_DIR="${HOME}/Library/Logs/life-ops"
STDOUT_PATH="${SERVICE_LOG_DIR}/cmail-service.out.log"
STDERR_PATH="${SERVICE_LOG_DIR}/cmail-service.err.log"
WATCHDOG_STDOUT_PATH="${SERVICE_LOG_DIR}/cmail-watchdog.out.log"
WATCHDOG_STDERR_PATH="${SERVICE_LOG_DIR}/cmail-watchdog.err.log"
WATCHDOG_RUNNER_PATH="${STATE_BIN_DIR}/cmail-watchdog"
SERVICE_HOST="${LIFE_OPS_CMAIL_HOST:-127.0.0.1}"
SERVICE_PORT="${LIFE_OPS_CMAIL_PORT:-4311}"
TAILSCALE_HTTPS_PORT="${LIFE_OPS_CMAIL_TAILSCALE_HTTPS_PORT:-4311}"
CMAIL_PUBLIC_URL="${LIFE_OPS_CMAIL_PUBLIC_URL:-https://cmail.tail649edd.ts.net}"
CMAIL_PUBLIC_URL="${CMAIL_PUBLIC_URL%/}"
TAILSCALE_URL_PATH="${STATE_ROOT}/config/cmail-tailscale-url"
UID_VALUE="$(id -u)"
PYTHON_BIN="${LIFE_OPS_PYTHON_BIN:-}"
VENV_DIR="${STATE_ROOT}/venvs/cmail"
VENV_PYTHON="${VENV_DIR}/bin/python"
BACKEND_DIR="${PACKAGE_DIR}/backend"
SERVICE_SECRETS_PATH="${STATE_ROOT}/config/service-secrets.json"

if [[ ! -f "${BACKEND_DIR}/pyproject.toml" ]]; then
  REPO_BACKEND_DIR="${PACKAGE_DIR:h:h}/src"
  REPO_ROOT="${PACKAGE_DIR:h:h}"
  if [[ -f "${REPO_ROOT}/pyproject.toml" && -d "${REPO_ROOT}/src/life_ops" ]]; then
    BACKEND_DIR="${REPO_ROOT}"
  fi
fi

usage() {
  cat <<EOF
Usage: cmail <command>

Commands:
  install   Bootstrap the bundled backend, write the LaunchAgent plist, and start the service
  start     Start or kickstart the installed service
  stop      Stop the running service without deleting the plist
  restart   Restart the installed service
  uninstall Stop the service and remove the LaunchAgent plist
  status    Show launchctl status for the service
  audit     Run a one-off CMAIL health audit and repair drift when possible
  tailscale Save/show the durable private CMAIL phone route
  tailscale-status
            Show the saved CMAIL tailnet URL and Tailscale Serve status
  secure-doctor
            Verify the canonical private CMAIL URL and health endpoint
  auth-code Show or create the optional private CMAIL unlock code
  tail      Tail the service logs
  plist     Print the expected LaunchAgent plist path
EOF
}

ensure_backend() {
  if [[ ! -f "${BACKEND_DIR}/pyproject.toml" ]]; then
    cat <<EOF
CMAIL backend not found.

Expected bundled backend at:
  ${PACKAGE_DIR}/backend

This install should come from the published lifeops package or a full local Life Ops checkout.
EOF
    exit 1
  fi
}

ensure_python() {
  if [[ -z "${PYTHON_BIN}" ]]; then
    echo "python3 is required to install CMAIL."
    exit 1
  fi
}

resolve_python_bin() {
  local candidates=()
  if [[ -n "${PYTHON_BIN}" ]]; then
    candidates+=("${PYTHON_BIN}")
  fi
  candidates+=(
    "${HOME}/.pyenv/shims/python3"
    "/opt/homebrew/bin/python3"
    "$(command -v python3 || true)"
  )
  local candidate
  for candidate in "${candidates[@]}"; do
    if [[ -n "${candidate}" && -x "${candidate}" ]]; then
      echo "${candidate}"
      return 0
    fi
  done
  return 1
}

ensure_venv() {
  ensure_backend
  PYTHON_BIN="$(resolve_python_bin || true)"
  ensure_python
  mkdir -p "${SERVICE_LOG_DIR}" "${STATE_ROOT}"
  local rebuild_venv=0
  if [[ ! -x "${VENV_PYTHON}" ]]; then
    rebuild_venv=1
  else
    local desired_version current_version
    desired_version="$("${PYTHON_BIN}" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')"
    current_version="$("${VENV_PYTHON}" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')"
    if [[ "${desired_version}" != "${current_version}" ]]; then
      rebuild_venv=1
    fi
  fi
  if [[ "${rebuild_venv}" -eq 1 ]]; then
    rm -rf "${VENV_DIR}"
    "${PYTHON_BIN}" -m venv "${VENV_DIR}"
  fi
  "${VENV_PYTHON}" -m pip install --upgrade pip setuptools wheel >/dev/null
  "${VENV_PYTHON}" -m pip install --upgrade --force-reinstall "${BACKEND_DIR}" >/dev/null
}

refresh_service_secrets() {
  if [[ ! -x "${VENV_PYTHON}" ]]; then
    echo "CMAIL backend environment not installed at ${VENV_PYTHON}. Run install first."
    exit 1
  fi
  LIFE_OPS_HOME="${STATE_ROOT}" LIFE_OPS_SERVICE_SECRETS_PATH="${SERVICE_SECRETS_PATH}" \
    "${VENV_PYTHON}" -c '
import os
from pathlib import Path
from life_ops.cmail_runtime import ensure_cmail_app_secret, write_cmail_service_secret_snapshot
secret_result = ensure_cmail_app_secret()
os.environ[secret_result["name"]] = secret_result["secret"]
result = write_cmail_service_secret_snapshot(target=Path("'"${SERVICE_SECRETS_PATH}"'"))
print(f"Secrets: {result['\''count'\'']} written to {result['\''path'\'']}")
if result["missing"]:
    print("Missing: " + ", ".join(result["missing"]))
'
}

run_health_audit() {
  if [[ ! -x "${VENV_PYTHON}" ]]; then
    echo "CMAIL backend environment not installed at ${VENV_PYTHON}. Run install first."
    exit 1
  fi
  LIFE_OPS_HOME="${STATE_ROOT}" LIFE_OPS_PACKAGE_ROOT="${BACKEND_DIR}" LIFE_OPS_SERVICE_SECRETS_PATH="${SERVICE_SECRETS_PATH}" \
    "${VENV_PYTHON}" -m life_ops cmail-health-check --repair --format json "${@}"
}

show_cmail_auth_code() {
  ensure_venv
  local rotate="0"
  local backend="auto"
  local allow_insecure_file_backend="0"
  local arg
  for arg in "${@}"; do
    case "${arg}" in
      --rotate)
        rotate="1"
        ;;
      --backend=*)
        backend="${arg#--backend=}"
        ;;
      --allow-insecure-file-backend)
        allow_insecure_file_backend="1"
        ;;
      *)
        echo "Unknown auth-code option: ${arg}" >&2
        exit 2
        ;;
    esac
  done
  CMAIL_AUTH_ROTATE="${rotate}" CMAIL_AUTH_BACKEND="${backend}" CMAIL_AUTH_ALLOW_INSECURE_FILE_BACKEND="${allow_insecure_file_backend}" \
  LIFE_OPS_HOME="${STATE_ROOT}" LIFE_OPS_PACKAGE_ROOT="${BACKEND_DIR}" LIFE_OPS_SERVICE_SECRETS_PATH="${SERVICE_SECRETS_PATH}" \
    "${VENV_PYTHON}" -c '
import os
from pathlib import Path
from life_ops.cmail_runtime import ensure_cmail_app_secret, write_cmail_service_secret_snapshot

result = ensure_cmail_app_secret(
    rotate=os.environ.get("CMAIL_AUTH_ROTATE") == "1",
    backend=os.environ.get("CMAIL_AUTH_BACKEND", "auto"),
    allow_insecure_file_backend=os.environ.get("CMAIL_AUTH_ALLOW_INSECURE_FILE_BACKEND") == "1",
)
os.environ[result["name"]] = result["secret"]
snapshot = write_cmail_service_secret_snapshot(target=Path(os.environ["LIFE_OPS_SERVICE_SECRETS_PATH"]))
state = "rotated" if result.get("rotated") else "created" if result.get("created") else "existing"
print("CMAIL unlock code:")
print(result["secret"])
print(f"State: {state}")
print(f"Service secrets: {snapshot['\''path'\'']}")
print("Keep this private. Restart CMAIL after rotating the code.")
'
}

render_plist() {
  cat <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>${VENV_PYTHON}</string>
    <string>-m</string>
    <string>life_ops</string>
    <string>cmail-serve</string>
    <string>--host</string>
    <string>${SERVICE_HOST}</string>
    <string>--port</string>
    <string>${SERVICE_PORT}</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>${HOME}</string>
    <key>PATH</key>
    <string>/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>LIFE_OPS_HOME</key>
    <string>${STATE_ROOT}</string>
    <key>LIFE_OPS_PACKAGE_ROOT</key>
    <string>${BACKEND_DIR}</string>
    <key>LIFE_OPS_SERVICE_SECRETS_PATH</key>
    <string>${SERVICE_SECRETS_PATH}</string>
    <key>LIFE_OPS_CMAIL_HOST</key>
    <string>${SERVICE_HOST}</string>
    <key>LIFE_OPS_CMAIL_PORT</key>
    <string>${SERVICE_PORT}</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>${STDOUT_PATH}</string>
  <key>StandardErrorPath</key>
  <string>${STDERR_PATH}</string>
</dict>
</plist>
EOF
}

render_watchdog_plist() {
  cat <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${WATCHDOG_LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>${WATCHDOG_RUNNER_PATH}</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>${HOME}</string>
    <key>PATH</key>
    <string>/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>LIFE_OPS_HOME</key>
    <string>${STATE_ROOT}</string>
    <key>LIFE_OPS_PACKAGE_ROOT</key>
    <string>${BACKEND_DIR}</string>
    <key>LIFE_OPS_SERVICE_SECRETS_PATH</key>
    <string>${SERVICE_SECRETS_PATH}</string>
  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>StartCalendarInterval</key>
  <array>
    <dict>
      <key>Hour</key>
      <integer>8</integer>
      <key>Minute</key>
      <integer>0</integer>
    </dict>
    <dict>
      <key>Hour</key>
      <integer>14</integer>
      <key>Minute</key>
      <integer>0</integer>
    </dict>
    <dict>
      <key>Hour</key>
      <integer>20</integer>
      <key>Minute</key>
      <integer>0</integer>
    </dict>
  </array>
  <key>StandardOutPath</key>
  <string>${WATCHDOG_STDOUT_PATH}</string>
  <key>StandardErrorPath</key>
  <string>${WATCHDOG_STDERR_PATH}</string>
</dict>
</plist>
EOF
}

render_watchdog_runner() {
  cat <<EOF
#!/bin/zsh
set -euo pipefail

LABEL="${LABEL}"
PLIST_PATH="${PLIST_PATH}"
UID_VALUE="\$(id -u)"
STATE_ROOT="${STATE_ROOT}"
BACKEND_DIR="${BACKEND_DIR}"
SERVICE_SECRETS_PATH="${SERVICE_SECRETS_PATH}"
VENV_PYTHON="${VENV_PYTHON}"

refresh_service_secrets() {
  LIFE_OPS_HOME="\${STATE_ROOT}" LIFE_OPS_SERVICE_SECRETS_PATH="\${SERVICE_SECRETS_PATH}" \\
    "\${VENV_PYTHON}" -c '
import os
from pathlib import Path
from life_ops.cmail_runtime import ensure_cmail_app_secret, write_cmail_service_secret_snapshot
secret_result = ensure_cmail_app_secret()
os.environ[secret_result["name"]] = secret_result["secret"]
write_cmail_service_secret_snapshot(target=Path("'"${SERVICE_SECRETS_PATH}"'"))
'
}

run_health_audit() {
  LIFE_OPS_HOME="\${STATE_ROOT}" LIFE_OPS_PACKAGE_ROOT="\${BACKEND_DIR}" LIFE_OPS_SERVICE_SECRETS_PATH="\${SERVICE_SECRETS_PATH}" \\
    "\${VENV_PYTHON}" -m life_ops cmail-health-check --repair --strict --format json "\$@"
}

refresh_service_secrets
if run_health_audit "\$@"; then
  exit 0
fi

echo "[cmail-watchdog] health audit failed; restarting \${LABEL}" >&2
if [[ ! -f "\${PLIST_PATH}" ]]; then
  echo "[cmail-watchdog] main service plist missing at \${PLIST_PATH}" >&2
  exit 1
fi

launchctl bootout "gui/\${UID_VALUE}" "\${PLIST_PATH}" >/dev/null 2>&1 || true
launchctl bootstrap "gui/\${UID_VALUE}" "\${PLIST_PATH}"
launchctl kickstart -k "gui/\${UID_VALUE}/\${LABEL}" >/dev/null 2>&1 || true
sleep 3
run_health_audit "\$@"
EOF
}

write_plist() {
  mkdir -p "${AGENT_DIR}"
  render_plist > "${PLIST_PATH}"
}

write_watchdog_plist() {
  mkdir -p "${AGENT_DIR}"
  render_watchdog_plist > "${WATCHDOG_PLIST_PATH}"
}

write_watchdog_runner() {
  mkdir -p "${STATE_BIN_DIR}"
  render_watchdog_runner > "${WATCHDOG_RUNNER_PATH}"
  chmod +x "${WATCHDOG_RUNNER_PATH}"
}

resolve_tailscale_bin() {
  local candidates=()
  candidates+=(
    "$(command -v tailscale || true)"
    "/Applications/Tailscale.app/Contents/MacOS/Tailscale"
    "/opt/homebrew/bin/tailscale"
    "/usr/local/bin/tailscale"
  )
  local candidate
  for candidate in "${candidates[@]}"; do
    if [[ -n "${candidate}" && -x "${candidate}" ]]; then
      echo "${candidate}"
      return 0
    fi
  done
  return 1
}

parse_tailscale_https_port() {
  local port="${TAILSCALE_HTTPS_PORT}"
  local args=("${@}")
  local index=1
  while [[ "${index}" -le "${#args[@]}" ]]; do
    case "${args[${index}]}" in
      --https-port)
        index=$((index + 1))
        if [[ "${index}" -gt "${#args[@]}" || -z "${args[${index}]}" ]]; then
          echo "--https-port requires a value" >&2
          return 2
        fi
        port="${args[${index}]}"
        ;;
      *)
        echo "Unknown tailscale option: ${args[${index}]}" >&2
        return 2
        ;;
    esac
    index=$((index + 1))
  done
  if ! [[ "${port}" =~ ^[0-9]+$ ]]; then
    echo "Tailscale HTTPS port must be numeric." >&2
    return 2
  fi
  echo "${port}"
}

tailscale_dns_name() {
  local tailscale_bin="${1}"
  local status_json
  status_json="$("${tailscale_bin}" status --json)"
  printf "%s" "${status_json}" | "${VENV_PYTHON}" -c '
import json
import sys

payload = json.load(sys.stdin)
print(str((payload.get("Self") or {}).get("DNSName") or "").rstrip("."))
'
}

tailscale_url_for_dns() {
  local dns_name="${1}"
  local https_port="${2}"
  if [[ -z "${dns_name}" ]]; then
    return 1
  fi
  if [[ "${https_port}" == "443" ]]; then
    echo "https://${dns_name}"
  else
    echo "https://${dns_name}:${https_port}"
  fi
}

configure_tailscale_serve() {
  local apply_compat_route="0"
  local filtered_args=()
  local raw_arg
  for raw_arg in "${@}"; do
    if [[ "${raw_arg}" == "--apply-compat-route" ]]; then
      apply_compat_route="1"
    else
      filtered_args+=("${raw_arg}")
    fi
  done

  local https_port
  https_port="$(parse_tailscale_https_port "${filtered_args[@]}")" || exit $?

  mkdir -p "${STATE_ROOT}/config"
  printf "%s\n" "${CMAIL_PUBLIC_URL}" > "${TAILSCALE_URL_PATH}"

  if [[ "${apply_compat_route}" != "1" ]]; then
    echo "Official phone URL: ${CMAIL_PUBLIC_URL}"
    echo "Local CMAIL URL: http://${SERVICE_HOST}:${SERVICE_PORT}"
    echo "Saved URL: ${TAILSCALE_URL_PATH}"
    echo "Shared Tailscale service-host routing is managed externally:"
    echo "  cmail.tail649edd.ts.net -> ${SERVICE_HOST}:${SERVICE_PORT}"
    echo "No Tailscale Serve configuration was changed."
    echo "Verify with: cmail secure-doctor"
    return 0
  fi

  ensure_venv
  refresh_service_secrets
  write_plist
  write_watchdog_runner
  write_watchdog_plist
  launchctl bootstrap "gui/${UID_VALUE}" "${PLIST_PATH}" >/dev/null 2>&1 || true
  launchctl bootstrap "gui/${UID_VALUE}" "${WATCHDOG_PLIST_PATH}" >/dev/null 2>&1 || true
  launchctl kickstart -k "gui/${UID_VALUE}/${LABEL}" >/dev/null 2>&1 || true
  launchctl kickstart -k "gui/${UID_VALUE}/${WATCHDOG_LABEL}" >/dev/null 2>&1 || true

  local tailscale_bin
  tailscale_bin="$(resolve_tailscale_bin || true)"
  if [[ -z "${tailscale_bin}" ]]; then
    echo "Tailscale CLI not found. Install Tailscale and sign in on this machine first."
    exit 1
  fi

  local dns_name compatibility_url
  dns_name="$(tailscale_dns_name "${tailscale_bin}")"
  if [[ -z "${dns_name}" ]]; then
    echo "Could not determine this machine's Tailscale DNS name. Make sure Tailscale is running and signed in."
    exit 1
  fi
  compatibility_url="$(tailscale_url_for_dns "${dns_name}" "${https_port}")"

  local output
  if ! output="$("${tailscale_bin}" serve --bg --yes --https "${https_port}" "http://${SERVICE_HOST}:${SERVICE_PORT}" 2>&1)"; then
    echo "${output}"
    if [[ "${output}" == *"Serve is not enabled on your tailnet."* ]]; then
      echo "Tailscale Serve is disabled on this tailnet. Enable Serve in the Tailscale admin console, then rerun: cmail tailscale"
    fi
    exit 1
  fi

  mkdir -p "${STATE_ROOT}/config"
  printf "%s\n" "${CMAIL_PUBLIC_URL}" > "${TAILSCALE_URL_PATH}"
  echo "CMAIL service: http://${SERVICE_HOST}:${SERVICE_PORT}"
  echo "Official phone URL: ${CMAIL_PUBLIC_URL}"
  echo "Compatibility URL: ${compatibility_url}"
  echo "Saved URL: ${TAILSCALE_URL_PATH}"
}

show_tailscale_status() {
  local tailscale_bin
  tailscale_bin="$(resolve_tailscale_bin || true)"
  echo "Official CMAIL phone URL: ${CMAIL_PUBLIC_URL}"
  if [[ -f "${TAILSCALE_URL_PATH}" ]]; then
    echo "Saved Tailscale URL: $(cat "${TAILSCALE_URL_PATH}")"
  else
    echo "Saved Tailscale URL: not configured"
  fi
  echo "Local CMAIL URL: http://${SERVICE_HOST}:${SERVICE_PORT}"
  if [[ -z "${tailscale_bin}" ]]; then
    echo "Tailscale CLI: not found"
    return 0
  fi
  echo "Tailscale CLI: ${tailscale_bin}"
  "${tailscale_bin}" serve status --json 2>/dev/null || echo "Tailscale Serve status: unavailable"
}

tailscale_secure_doctor() {
  local https_port
  https_port="$(parse_tailscale_https_port "${@}")" || exit $?

  local tailscale_bin
  tailscale_bin="$(resolve_tailscale_bin || true)"
  if [[ -z "${tailscale_bin}" ]]; then
    echo "CMAIL secure doctor: FAIL"
    echo "- tailscale_cli: missing"
    exit 1
  fi

  local python_bin
  if [[ -x "${VENV_PYTHON}" ]]; then
    python_bin="${VENV_PYTHON}"
  else
    python_bin="$(resolve_python_bin || true)"
  fi
  if [[ -z "${python_bin}" ]]; then
    echo "CMAIL secure doctor: FAIL"
    echo "- python: missing"
    exit 1
  fi

  local dns_name official_url compatibility_url expected_proxy serve_json funnel_json serve_text health_body compatibility_health_body auth_body
  dns_name="$(tailscale_dns_name "${tailscale_bin}")"
  official_url="${CMAIL_PUBLIC_URL}"
  compatibility_url="$(tailscale_url_for_dns "${dns_name}" "${https_port}")"
  expected_proxy="http://${SERVICE_HOST}:${SERVICE_PORT}"
  serve_json="$("${tailscale_bin}" serve status --json 2>&1)"
  funnel_json="$("${tailscale_bin}" funnel status --json 2>&1)"
  serve_text="$("${tailscale_bin}" serve status 2>&1)"

  local doctor_json
  doctor_json="$(SERVE_JSON="${serve_json}" FUNNEL_JSON="${funnel_json}" SERVE_TEXT="${serve_text}" DNS_NAME="${dns_name}" HTTPS_PORT="${https_port}" EXPECTED_PROXY="${expected_proxy}" OFFICIAL_URL="${official_url}" COMPATIBILITY_URL="${compatibility_url}" "${python_bin}" -c '
import json
import os
import sys


def load_json(name: str) -> dict:
    raw = os.environ.get(name, "")
    start = raw.find("{")
    if start < 0:
        raise ValueError(f"{name} did not include JSON")
    return json.loads(raw[start:])


def truthy_funnel_flags(value, path=""):
    found = []
    if isinstance(value, dict):
        for key, child in value.items():
            clean = str(key).lower()
            child_path = f"{path}.{key}" if path else str(key)
            if clean in {"funnel", "allowfunnel", "funnelon", "funnelenabled"} and child is True:
                found.append(child_path)
            found.extend(truthy_funnel_flags(child, child_path))
    elif isinstance(value, list):
        for index, child in enumerate(value):
            found.extend(truthy_funnel_flags(child, f"{path}[{index}]"))
    return found


serve = load_json("SERVE_JSON")
funnel = load_json("FUNNEL_JSON")
serve_text = os.environ.get("SERVE_TEXT", "")
dns_name = os.environ["DNS_NAME"]
https_port = os.environ["HTTPS_PORT"]
expected_proxy = os.environ["EXPECTED_PROXY"]
official_url = os.environ["OFFICIAL_URL"]
compatibility_url = os.environ["COMPATIBILITY_URL"]
host_key = f"{dns_name}:{https_port}"

checks = []
routes = []
for host, host_payload in (serve.get("Web") or {}).items():
    for path, handler in (host_payload.get("Handlers") or {}).items():
        proxy = str((handler or {}).get("Proxy") or "")
        routes.append({"host": str(host), "path": str(path), "proxy": proxy})

tcp = serve.get("TCP") or {}
web = serve.get("Web") or {}
official_handler = (((web.get(host_key) or {}).get("Handlers") or {}).get("/") or {})
official_proxy = str(official_handler.get("Proxy") or "")
official_tcp = bool((tcp.get(str(https_port)) or {}).get("HTTPS"))
cmail_routes = [route for route in routes if route["proxy"] == expected_proxy]
unexpected_cmail_routes = [
    route for route in cmail_routes
    if not (route["host"] == host_key and route["path"] == "/")
]
tailnet_only = f"{compatibility_url} (tailnet only)" in serve_text
funnel_flags = truthy_funnel_flags(funnel)
funnel_text_suspicious = "Funnel on" in serve_text or "funnel on" in serve_text.lower()

checks.append({"name": "compatibility_serve_route", "ok": official_proxy == expected_proxy, "detail": official_proxy or "missing"})
checks.append({"name": "compatibility_https_port", "ok": official_tcp, "detail": str((tcp.get(str(https_port)) or {}))})
checks.append({"name": "compatibility_tailnet_only", "ok": tailnet_only, "detail": "tailnet only" if tailnet_only else "not proven tailnet-only"})
checks.append({"name": "funnel_disabled", "ok": not funnel_flags and not funnel_text_suspicious, "detail": ", ".join(funnel_flags) if funnel_flags else "no public Funnel flags"})
checks.append({"name": "no_extra_cmail_routes", "ok": not unexpected_cmail_routes, "detail": unexpected_cmail_routes})

payload = {
    "ok": all(check["ok"] for check in checks),
    "official_url": official_url,
    "compatibility_url": compatibility_url,
    "expected_proxy": expected_proxy,
    "checks": checks,
    "cmail_routes": cmail_routes,
    "other_routes": [route for route in routes if route["proxy"] != expected_proxy],
}
print(json.dumps(payload))
sys.exit(0 if payload["ok"] else 1)
')" || {
    echo "CMAIL secure doctor: FAIL"
    echo "- route_check: failed"
    printf "%s\n" "${doctor_json:-}"
    exit 1
  }

  local doctor_ok
  doctor_ok="$(printf "%s" "${doctor_json}" | "${python_bin}" -c 'import json,sys; print("1" if json.load(sys.stdin).get("ok") else "0")')"

  health_body="$(curl -fsS "${official_url}/healthz" 2>&1)" || {
    echo "CMAIL secure doctor: FAIL"
    printf "%s" "${doctor_json}" | "${python_bin}" -m json.tool
    echo "- canonical_health_check: failed"
    echo "${health_body}"
    exit 1
  }
  compatibility_health_body="$(curl -fsS "${compatibility_url}/healthz" 2>&1)" || {
    echo "CMAIL secure doctor: FAIL"
    printf "%s" "${doctor_json}" | "${python_bin}" -m json.tool
    echo "- compatibility_health_check: failed"
    echo "${compatibility_health_body}"
    exit 1
  }
  auth_body="$(curl -fsS "${official_url}/api/auth/status" 2>&1)" || {
    echo "CMAIL secure doctor: FAIL"
    printf "%s" "${doctor_json}" | "${python_bin}" -m json.tool
    echo "- app_auth_status_check: failed"
    echo "${auth_body}"
    exit 1
  }

  local health_ok auth_ok
  health_ok="$(HEALTH_BODY="${health_body}" "${python_bin}" -c 'import json, os; payload=json.loads(os.environ["HEALTH_BODY"]); print("1" if payload.get("ok") is True and payload.get("app") == "cmail" else "0")' 2>/dev/null || echo "0")"
  auth_ok="$(AUTH_BODY="${auth_body}" "${python_bin}" -c 'import json, os; payload=json.loads(os.environ["AUTH_BODY"]); print("1" if payload.get("ok") is True and payload.get("app") == "cmail" and (payload.get("auth_required") is not True or payload.get("auth_configured") is True) else "0")' 2>/dev/null || echo "0")"
  if [[ "${doctor_ok}" != "1" || "${health_ok}" != "1" || "${auth_ok}" != "1" ]]; then
    echo "CMAIL secure doctor: FAIL"
    printf "%s" "${doctor_json}" | "${python_bin}" -m json.tool
    echo "- health_response: ${health_body}"
    echo "- auth_status_response: ${auth_body}"
    exit 1
  fi

  echo "CMAIL secure doctor: OK"
  echo "Official URL: ${official_url}"
  echo "Compatibility URL: ${compatibility_url}"
  echo "Expected proxy: ${expected_proxy}"
  printf "%s" "${doctor_json}" | "${python_bin}" -c '
import json
import sys
payload = json.load(sys.stdin)
for check in payload["checks"]:
    print(f"- {check['\''name'\'']}: {'\''ok'\'' if check['\''ok'\''] else '\''fail'\''} ({check['\''detail'\'']})")
if payload["other_routes"]:
    print("- other_tailnet_routes: present but not CMAIL")
    for route in payload["other_routes"]:
        print(f"  {route['\''host'\'']}{route['\''path'\'']} -> {route['\''proxy'\'']}")
else:
    print("- other_tailnet_routes: none")
'
  echo "Canonical health: ${health_body}"
  echo "Compatibility health: ${compatibility_health_body}"
  echo "App auth status: ${auth_body}"
}

command_name="${1:-status}"

case "${command_name}" in
  install)
    ensure_venv
    refresh_service_secrets
    write_plist
    write_watchdog_runner
    write_watchdog_plist
    launchctl bootout "gui/${UID_VALUE}" "${PLIST_PATH}" >/dev/null 2>&1 || true
    launchctl bootout "gui/${UID_VALUE}" "${WATCHDOG_PLIST_PATH}" >/dev/null 2>&1 || true
    launchctl bootstrap "gui/${UID_VALUE}" "${PLIST_PATH}"
    launchctl bootstrap "gui/${UID_VALUE}" "${WATCHDOG_PLIST_PATH}"
    launchctl kickstart -k "gui/${UID_VALUE}/${LABEL}" >/dev/null 2>&1 || true
    launchctl kickstart -k "gui/${UID_VALUE}/${WATCHDOG_LABEL}" >/dev/null 2>&1 || true
    echo "Installed and started ${LABEL}."
    echo "Plist: ${PLIST_PATH}"
    echo "Watchdog plist: ${WATCHDOG_PLIST_PATH}"
    echo "Home: ${STATE_ROOT}"
    echo "Backend: ${BACKEND_DIR}"
    echo "Python: ${VENV_PYTHON}"
    echo "Service secrets: ${SERVICE_SECRETS_PATH}"
    echo "Local URL: http://${SERVICE_HOST}:${SERVICE_PORT}"
    if [[ -f "${TAILSCALE_URL_PATH}" ]]; then
      echo "Tailscale URL: $(cat "${TAILSCALE_URL_PATH}")"
    else
      echo "Tailscale URL: not configured"
    fi
    ;;
  start)
    if [[ ! -f "${PLIST_PATH}" ]]; then
      echo "LaunchAgent plist not found at ${PLIST_PATH}. Run install first."
      exit 1
    fi
    ensure_venv
    refresh_service_secrets
    write_plist
    write_watchdog_runner
    write_watchdog_plist
    launchctl bootstrap "gui/${UID_VALUE}" "${PLIST_PATH}" >/dev/null 2>&1 || true
    launchctl bootstrap "gui/${UID_VALUE}" "${WATCHDOG_PLIST_PATH}" >/dev/null 2>&1 || true
    launchctl kickstart -k "gui/${UID_VALUE}/${LABEL}" >/dev/null 2>&1 || true
    launchctl kickstart -k "gui/${UID_VALUE}/${WATCHDOG_LABEL}" >/dev/null 2>&1 || true
    echo "Started ${LABEL}."
    ;;
  stop)
    if [[ ! -f "${PLIST_PATH}" ]]; then
      echo "LaunchAgent plist not found at ${PLIST_PATH}."
      exit 0
    fi
    launchctl bootout "gui/${UID_VALUE}" "${PLIST_PATH}" >/dev/null 2>&1 || true
    launchctl bootout "gui/${UID_VALUE}" "${WATCHDOG_PLIST_PATH}" >/dev/null 2>&1 || true
    echo "Stopped ${LABEL}."
    ;;
  restart)
    if [[ ! -f "${PLIST_PATH}" ]]; then
      echo "LaunchAgent plist not found at ${PLIST_PATH}. Run install first."
      exit 1
    fi
    ensure_venv
    refresh_service_secrets
    write_plist
    write_watchdog_runner
    write_watchdog_plist
    launchctl bootout "gui/${UID_VALUE}" "${PLIST_PATH}" >/dev/null 2>&1 || true
    launchctl bootout "gui/${UID_VALUE}" "${WATCHDOG_PLIST_PATH}" >/dev/null 2>&1 || true
    launchctl bootstrap "gui/${UID_VALUE}" "${PLIST_PATH}"
    launchctl bootstrap "gui/${UID_VALUE}" "${WATCHDOG_PLIST_PATH}"
    launchctl kickstart -k "gui/${UID_VALUE}/${LABEL}" >/dev/null 2>&1 || true
    launchctl kickstart -k "gui/${UID_VALUE}/${WATCHDOG_LABEL}" >/dev/null 2>&1 || true
    echo "Restarted ${LABEL}."
    ;;
  uninstall)
    launchctl bootout "gui/${UID_VALUE}" "${PLIST_PATH}" >/dev/null 2>&1 || true
    launchctl bootout "gui/${UID_VALUE}" "${WATCHDOG_PLIST_PATH}" >/dev/null 2>&1 || true
    rm -f "${PLIST_PATH}"
    rm -f "${WATCHDOG_PLIST_PATH}"
    rm -f "${WATCHDOG_RUNNER_PATH}"
    echo "Uninstalled ${LABEL}."
    ;;
  status)
    echo "Label: ${LABEL}"
    echo "Plist: ${PLIST_PATH}"
    echo "Watchdog label: ${WATCHDOG_LABEL}"
    echo "Watchdog plist: ${WATCHDOG_PLIST_PATH}"
    echo "Watchdog runner: ${WATCHDOG_RUNNER_PATH}"
    echo "Home: ${STATE_ROOT}"
    echo "Backend: ${BACKEND_DIR}"
    echo "Python: ${VENV_PYTHON}"
    echo "Service secrets: ${SERVICE_SECRETS_PATH}"
    echo "Local URL: http://${SERVICE_HOST}:${SERVICE_PORT}"
    if [[ -f "${TAILSCALE_URL_PATH}" ]]; then
      echo "Tailscale URL: $(cat "${TAILSCALE_URL_PATH}")"
    else
      echo "Tailscale URL: not configured"
    fi
    if [[ -f "${PLIST_PATH}" ]]; then
      launchctl print "gui/${UID_VALUE}/${LABEL}" 2>/dev/null || echo "launchctl: service not loaded"
    else
      echo "launchctl: plist not installed"
    fi
    if [[ -f "${WATCHDOG_PLIST_PATH}" ]]; then
      launchctl print "gui/${UID_VALUE}/${WATCHDOG_LABEL}" 2>/dev/null || echo "launchctl: watchdog not loaded"
    else
      echo "launchctl: watchdog plist not installed"
    fi
    ;;
  audit)
    refresh_service_secrets
    run_health_audit "${@:2}"
    ;;
  tailscale)
    configure_tailscale_serve "${@:2}"
    ;;
  tailscale-status)
    show_tailscale_status
    ;;
  secure-doctor)
    tailscale_secure_doctor "${@:2}"
    ;;
  auth-code)
    show_cmail_auth_code "${@:2}"
    ;;
  watchdog-run)
    refresh_service_secrets
    if run_health_audit --strict "${@:2}"; then
      exit 0
    fi
    echo "[cmail-watchdog] health audit failed; restarting ${LABEL}" >&2
    if [[ ! -f "${PLIST_PATH}" ]]; then
      echo "[cmail-watchdog] main service plist missing at ${PLIST_PATH}" >&2
      exit 1
    fi
    write_plist
    launchctl bootout "gui/${UID_VALUE}" "${PLIST_PATH}" >/dev/null 2>&1 || true
    launchctl bootstrap "gui/${UID_VALUE}" "${PLIST_PATH}"
    launchctl kickstart -k "gui/${UID_VALUE}/${LABEL}" >/dev/null 2>&1 || true
    sleep 3
    run_health_audit --strict "${@:2}"
    ;;
  tail)
    mkdir -p "${SERVICE_LOG_DIR}"
    touch "${STDOUT_PATH}" "${STDERR_PATH}" "${WATCHDOG_STDOUT_PATH}" "${WATCHDOG_STDERR_PATH}"
    exec tail -f "${STDOUT_PATH}" "${STDERR_PATH}" "${WATCHDOG_STDOUT_PATH}" "${WATCHDOG_STDERR_PATH}"
    ;;
  plist)
    echo "${PLIST_PATH}"
    ;;
  *)
    usage
    exit 1
    ;;
esac
